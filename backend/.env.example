# ═══════════════════════════════════════════════════════════════════════════════
# Emby AI 中文字幕生成服务 - 环境配置
# ═══════════════════════════════════════════════════════════════════════════════
#
# 此文件仅包含基础设施配置（数据库、Redis、日志等）。
# 业务配置（Emby、ASR、翻译、VAD、Telegram 等）请通过 Web UI 设置页面管理。
#
# 使用方法：复制此文件为 .env 并根据需要修改。
# 所有配置项都有默认值，不创建 .env 文件也能启动。
# ═══════════════════════════════════════════════════════════════════════════════

# 应用配置
# DEBUG=False

# ─────────────────────────────────────────────────────────────────────────────
# 数据库配置
# ─────────────────────────────────────────────────────────────────────────────
# 默认: sqlite:///./subtitle_service.db
# DATABASE_URL=sqlite:///./subtitle_service.db

# ─────────────────────────────────────────────────────────────────────────────
# Redis 配置（Celery 消息队列）
# ─────────────────────────────────────────────────────────────────────────────
# 默认: redis://localhost:6379/0
# 有密码: redis://:password@host:6379/0
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# 日志配置
# ─────────────────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FILE=logs/subtitle_service.log

# ─────────────────────────────────────────────────────────────────────────────
# 模型与临时文件存储（也可通过 UI 设置页面配置）
# ─────────────────────────────────────────────────────────────────────────────
# MODEL_STORAGE_DIR=./data/models
# TEMP_DIR=./data
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
