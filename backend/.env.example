# 应用配置
APP_NAME=Emby AI 中文字幕生成服务
DEBUG=False

# 数据库配置
# 本地开发使用相对路径
DATABASE_URL=sqlite:///./subtitle_service.db
# 或使用绝对路径
# DATABASE_URL=sqlite:///C:/path/to/subtitle_service.db

# Redis 配置
# 本地 Redis: redis://localhost:6379/0
# 远程 Redis: redis://remote-host:6379/0
# 有密码: redis://:password@host:6379/0
# 云服务: redis://username:password@host:port/0
REDIS_URL=redis://localhost:6379/0

# Celery 配置（使用相同的 Redis）
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Emby 配置
EMBY_URL=http://your-emby-server:8096
EMBY_API_KEY=your-emby-api-key

# ASR 配置
ASR_ENGINE=sherpa-onnx
ASR_MODEL_PATH=/path/to/sherpa-onnx/model
CLOUD_ASR_URL=
CLOUD_ASR_API_KEY=

# 翻译服务配置
TRANSLATION_SERVICE=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
DEEPSEEK_API_KEY=
LOCAL_LLM_URL=

# 任务配置
MAX_CONCURRENT_TASKS=2
# Windows 使用绝对路径，如: C:/temp/subtitle_service
# Linux/Mac 使用: /tmp/subtitle_service
TEMP_DIR=/tmp/subtitle_service

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/subtitle_service.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days
