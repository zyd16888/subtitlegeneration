# 应用配置
APP_NAME=Emby AI 中文字幕生成服务
DEBUG=False

# 数据库配置
# 本地开发使用相对路径
DATABASE_URL=sqlite:///./subtitle_service.db
# 或使用绝对路径
# DATABASE_URL=sqlite:///C:/path/to/subtitle_service.db

# Redis 配置
# 本地 Redis: redis://localhost:6379/0
# 远程 Redis: redis://remote-host:6379/0
# 有密码: redis://:password@host:6379/0
# 云服务: redis://username:password@host:port/0
REDIS_URL=redis://localhost:6379/0

# Celery 配置（使用相同的 Redis）
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Emby 配置
EMBY_URL=http://your-emby-server:8096
EMBY_API_KEY=your-emby-api-key

# ─────────────────────────────────────────────────────────────────────────────
# ASR 语音识别配置
# ─────────────────────────────────────────────────────────────────────────────

# ASR 引擎类型: sherpa-onnx 或 cloud
ASR_ENGINE=sherpa-onnx

# 模型 ID（推荐：从模型管理器下载后使用 ID）
# 日语推荐模型:
#   - zipformer-ja-reazonspeech (日语专用，速度快)
#   - whisper-medium (多语言，效果好)
#   - whisper-large-v3 (效果最好，需要更多资源)
# ASR_MODEL_ID=whisper-medium

# 或手动指定模型路径（不推荐）
# ASR_MODEL_PATH=/path/to/sherpa-onnx/model

# 云端 ASR（如果使用 cloud 引擎）
CLOUD_ASR_URL=
CLOUD_ASR_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# VAD 语音活动检测配置（参考官方 generate-subtitles.py 推荐）
# ─────────────────────────────────────────────────────────────────────────────

# 是否启用 VAD（强烈推荐启用，获得精确时间戳）
ENABLE_VAD=true

# VAD 模型 ID（需要在设置页面下载 silero_vad 模型）
# VAD_MODEL_ID=silero_vad

# VAD 参数（官方推荐值，通常无需修改）
VAD_THRESHOLD=0.2
VAD_MIN_SILENCE_DURATION=0.25
VAD_MIN_SPEECH_DURATION=0.25
VAD_MAX_SPEECH_DURATION=5.0

# ─────────────────────────────────────────────────────────────────────────────
# 语言配置
# ─────────────────────────────────────────────────────────────────────────────

# 源语言（日语视频用 ja，中文用 zh，英语用 en）
SOURCE_LANGUAGE=ja
TARGET_LANGUAGE=zh

# ─────────────────────────────────────────────────────────────────────────────
# 翻译服务配置
# ─────────────────────────────────────────────────────────────────────────────

# 翻译服务: openai, deepseek, local, google, microsoft, baidu, deepl
TRANSLATION_SERVICE=openai

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# DeepSeek
DEEPSEEK_API_KEY=

# 本地 LLM
LOCAL_LLM_URL=

# Google 翻译
GOOGLE_TRANSLATE_MODE=free
GOOGLE_API_KEY=

# 微软翻译
MICROSOFT_TRANSLATE_MODE=free
MICROSOFT_API_KEY=
MICROSOFT_REGION=global

# 百度翻译
BAIDU_APP_ID=
BAIDU_SECRET_KEY=

# DeepL
DEEPL_MODE=deeplx
DEEPL_API_KEY=
DEEPLX_URL=http://localhost:1188

# ─────────────────────────────────────────────────────────────────────────────
# 任务配置
# ─────────────────────────────────────────────────────────────────────────────

MAX_CONCURRENT_TASKS=2

# 临时文件目录
# Windows: C:/temp/subtitle_service
# Linux/Mac: /tmp/subtitle_service
TEMP_DIR=/tmp/subtitle_service

# ─────────────────────────────────────────────────────────────────────────────
# 日志配置
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
LOG_FILE=logs/subtitle_service.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# ─────────────────────────────────────────────────────────────────────────────
# 模型存储目录（可选，默认使用跨平台路径）
# ─────────────────────────────────────────────────────────────────────────────

# MODEL_STORAGE_DIR=/path/to/models
